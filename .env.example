# PostgreSQL (used only by docker-compose.prod.yml to init the container)
POSTGRES_DB=lumo_signal
POSTGRES_USER=lumo
POSTGRES_PASSWORD=change_me_strong_password

# App — DATABASE_URL is assembled from the vars above inside docker-compose.prod.yml
# For local dev keep the line below uncommented:
# DATABASE_URL=postgres://lumo:lumo_dev_password@localhost:5433/lumo_signal
DATABASE_POOL_SIZE=10

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# Publicly accessible URL of the app (no trailing slash)
AUTH_URL=https://your-domain.com

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_YANDEX_ID=
AUTH_YANDEX_SECRET=
AUTH_VK_ID=
AUTH_VK_SECRET=

# Comma-separated list of emails allowed into the admin area (/admin/pricing).
ADMIN_EMAILS=

# 32 random bytes encoded as base64.
GIFT_CARD_ENCRYPTION_KEY=

# HMAC key for the digital_access_log tamper-evidence chain (base64, >=32 bytes).
# Kept out of the DB (which is shared with the market service) so the audit chain
# can't be silently rewritten by someone with only DB access. Treat as long-lived
# — rotating it invalidates verification of historical rows.
AUDIT_CHAIN_HMAC_KEY=

# NS.gifts wholesale API (wholesale.ns.gifts) — used by the admin catalog to
# browse services and buy codes into inventory.
NS_GIFTS_USER_ID=
NS_GIFTS_LOGIN=
NS_GIFTS_PASSWORD=
NS_GIFTS_API_SECRET=
# Optional; defaults to https://api.ns.gifts
NS_GIFTS_BASE_URL=

# Email adapter is intentionally provider-neutral for now.
EMAIL_PROVIDER=

# PayPalych payment gateway (brands: Pally / pally.info, API host pal24.pro).
# Token + shop id come from the API integrations page in the merchant dashboard.
# The shop's Result URL (server postback) must point at /api/payments/paypalych/callback.
PAYMENT_PROVIDER=paypalych
PAYPALYCH_API_TOKEN=
PAYPALYCH_SHOP_ID=
# Optional; defaults to https://pal24.pro
PAYPALYCH_BASE_URL=

# Shared secret for the internal fulfilment/delivery worker route
# (/api/internal/fulfillment), called by the lumo-fulfillment systemd timer.
# Generate with: openssl rand -hex 32. Without it the worker route is disabled.
INTERNAL_WORKER_SECRET=

# Telegram operational alerts (e.g. PlayStation-account stock running low/out).
# BOT_TOKEN from @BotFather; ALERT_CHAT_ID is the numeric chat/channel id the
# bot posts to (add the bot to that chat first). Missing = alerts disabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# Support form → email (Beget SMTP for the support@lumo-store.ru mailbox).
# Without these, the "Написать в поддержку" form returns a friendly error.
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=support@lumo-store.ru
SMTP_PASS=
SUPPORT_EMAIL=support@lumo-store.ru

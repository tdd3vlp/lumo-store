# PostgreSQL (used only by docker-compose.prod.yml to init the container)
POSTGRES_DB=lumo_signal
POSTGRES_USER=lumo
POSTGRES_PASSWORD=change_me_strong_password

# App — DATABASE_URL is assembled from the vars above inside docker-compose.prod.yml
# For local dev keep the line below uncommented:
# DATABASE_URL=postgres://lumo:lumo_dev_password@localhost:5433/lumo_signal
DATABASE_POOL_SIZE=10

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# Publicly accessible URL of the app (no trailing slash)
AUTH_URL=https://your-domain.com

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_YANDEX_ID=
AUTH_YANDEX_SECRET=
AUTH_VK_ID=
AUTH_VK_SECRET=

# Comma-separated list of emails allowed into the admin area (/admin/pricing).
ADMIN_EMAILS=

# 32 random bytes encoded as base64.
GIFT_CARD_ENCRYPTION_KEY=

# NS.gifts wholesale API (wholesale.ns.gifts) — used by the admin catalog to
# browse services and buy codes into inventory.
NS_GIFTS_USER_ID=
NS_GIFTS_LOGIN=
NS_GIFTS_PASSWORD=
NS_GIFTS_API_SECRET=
# Optional; defaults to https://api.ns.gifts
NS_GIFTS_BASE_URL=

# Email/payment adapters are intentionally provider-neutral for now.
EMAIL_PROVIDER=
PAYMENT_PROVIDER=
